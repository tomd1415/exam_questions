# OCR copyright material — pattern source only, never committed.
# CONTENT_INDEX.md is our own catalogue and is allowed.
OCR_Docs/**
!OCR_Docs/CONTENT_INDEX.md

# Curated source content (when populated) is treated the same way.
content/source/**

# Secrets and local config
.env
.env.*
!.env.example

# Node / build artefacts
node_modules/
dist/
build/
coverage/
*.log
.DS_Store

# Local dev scratch (DB dumps from npm run db:backup, etc.)
tmp/

# Editor — keep shared VSCode config, ignore per-user files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.swp

# TypeScript / test artefacts
*.tsbuildinfo
.vitest/

# Claude Code per-project scratch (locks, schedules)
.claude/
# Eval reports land here at runtime; keep the committed fixtures in prompts/eval/ only.
scripts/eval/out/

# OS
Thumbs.db
