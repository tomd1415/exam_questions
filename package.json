{
  "name": "exam-questions",
  "version": "0.0.0",
  "private": true,
  "description": "OCR J277 revision platform — adaptive, teacher-moderated, LLM-assisted.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <25"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json && npm run build:assets",
    "build:assets": "node --input-type=module -e \"import {cpSync,rmSync} from 'node:fs'; rmSync('dist/templates',{recursive:true,force:true}); rmSync('dist/static',{recursive:true,force:true}); cpSync('src/templates','dist/templates',{recursive:true}); cpSync('src/static','dist/static',{recursive:true});\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:psql": "docker compose exec postgres psql -U exam -d exam_dev",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:backup": "BACKUP_DIR=${BACKUP_DIR:-./tmp/backups} PG_DUMP='docker compose exec -T postgres pg_dump -U exam' PGDATABASE=exam_dev bash scripts/backup-db.sh",
    "db:restore-drill": "BACKUP_DIR=${BACKUP_DIR:-./tmp/backups} PG_RESTORE='docker compose exec -T postgres pg_restore -U exam' PSQL='docker compose exec -T postgres psql -U exam' PGDATABASE=exam_dev bash scripts/restore-drill.sh",
    "user:create": "tsx src/scripts/create-user.ts",
    "content:seed": "tsx src/scripts/seed-curated-content.ts",
    "test:human:phase0": "bash scripts/human-test-phase0.sh",
    "test:human:phase1": "bash scripts/human-test-phase1.sh",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test:coverage"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^9.1.1",
    "@fastify/view": "^11.1.1",
    "@node-rs/argon2": "^2.0.2",
    "dotenv": "^16.4.5",
    "eta": "^4.5.1",
    "fastify": "^5.8.5",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.1",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5"
  }
}
