<%
const widget = (it.draft.payload || {}).expected_response_type || '';
%>
<fieldset class="wizard-step wizard-step--5 wizard-step--noop">
  <legend class="visually-hidden">No widget configuration needed</legend>
  <p>
    The <strong><%= widget %></strong> widget doesn&rsquo;t need any extra
    setup &mdash; mark points alone are enough. Press <strong>Save and continue</strong>
    to move on to marks and the model answer.
  </p>
</fieldset>
