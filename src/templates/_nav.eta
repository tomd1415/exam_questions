<%
const user = it.currentUser;
const currentPath = it.currentPath || '/';

function navLinksFor(role) {
  if (role === 'pupil') {
    return [
      { href: '/', label: 'Home', match: ['/', '/topics'], key: 'home', icon: 'home' },
      { href: '/topics', label: 'Topics', match: ['/topics'], key: 'topics', icon: 'book' },
      { href: '/me/attempts', label: 'My attempts', match: ['/me/attempts', '/attempts'], key: 'attempts', icon: 'file-text' },
      { href: '/feedback', label: 'Feedback', match: ['/feedback'], key: 'feedback', icon: 'pencil-line' },
      { href: '/me/preferences', label: 'Preferences', match: ['/me/preferences'], key: 'prefs', icon: 'settings' },
    ];
  }
  if (role === 'teacher' || role === 'admin') {
    const base = [
      { href: '/', label: 'Home', match: ['/'], key: 'home', icon: 'home' },
      { href: '/admin/classes', label: 'Classes', match: ['/admin/classes'], key: 'classes', icon: 'users' },
      { href: '/admin/questions', label: 'Questions', match: ['/admin/questions'], key: 'questions', icon: 'clipboard-check' },
      { href: '/admin/topics', label: 'Topics', match: ['/admin/topics'], key: 'topics', icon: 'book' },
      { href: '/admin/attempts', label: 'Marking queue', match: ['/admin/attempts'], key: 'queue', icon: 'list-checks' },
      { href: '/admin/moderation', label: 'AI moderation', match: ['/admin/moderation'], key: 'moderation', icon: 'shield-check' },
      { href: '/admin/feedback', label: 'Feedback', match: ['/admin/feedback', '/feedback'], key: 'feedback', icon: 'pencil-line' },
      { href: '/me/preferences', label: 'Preferences', match: ['/me/preferences'], key: 'prefs', icon: 'settings' },
    ];
    if (role === 'admin') {
      base.push({ href: '/admin/users', label: 'Users', match: ['/admin/users'], key: 'users', icon: 'user-check' });
      base.push({ href: '/admin/prompts/versions', label: 'Prompts', match: ['/admin/prompts'], key: 'prompts', icon: 'file-text' });
      base.push({ href: '/admin/content-guards', label: 'Content guards', match: ['/admin/content-guards'], key: 'guards', icon: 'shield' });
      base.push({ href: '/admin/llm/costs', label: 'LLM costs', match: ['/admin/llm'], key: 'llm-costs', icon: 'file-text' });
      base.push({ href: '/admin/evals/latest', label: 'Prompt evals', match: ['/admin/evals'], key: 'evals', icon: 'clipboard-check' });
      base.push({ href: '/admin/audit', label: 'Audit log', match: ['/admin/audit'], key: 'audit', icon: 'file-text' });
    }
    return base;
  }
  return [];
}

function isActive(link) {
  for (const prefix of link.match) {
    if (prefix === '/') {
      if (currentPath === '/') return true;
    } else if (currentPath === prefix || currentPath.startsWith(prefix + '/')) {
      return true;
    }
  }
  return false;
}

const links = user ? navLinksFor(user.role) : [];
%>
<% if (user) { %>
  <nav class="site-nav" aria-label="Primary">
    <button type="button"
            class="btn btn--ghost btn--sm site-nav__toggle"
            aria-expanded="false"
            aria-controls="primary-nav-drawer"
            data-nav-toggle>
      <span class="site-nav__toggle-label">Menu</span>
    </button>
    <ul class="site-nav__list" id="primary-nav-drawer" role="list">
      <% links.forEach(function(link) { %>
        <% const active = isActive(link); %>
        <li class="site-nav__item<%= active ? ' site-nav__item--active' : '' %>">
          <% if (active) { %>
            <a href="<%= link.href %>" aria-current="page">
              <% if (link.icon) { %><%~ include('_icon', { name: link.icon }) %><% } %>
              <span class="site-nav__label"><%= link.label %></span>
            </a>
          <% } else { %>
            <a href="<%= link.href %>">
              <% if (link.icon) { %><%~ include('_icon', { name: link.icon }) %><% } %>
              <span class="site-nav__label"><%= link.label %></span>
            </a>
          <% } %>
        </li>
      <% }); %>
    </ul>
  </nav>
<% } %>
