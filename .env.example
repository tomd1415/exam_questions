# Copy to .env for local development. Never commit .env.
# Values below are safe defaults for local dev against the Docker Postgres.

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database (matches docker-compose.yml defaults; change for production)
DATABASE_URL=postgres://exam:exam@localhost:5433/exam_dev

# Sessions — generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_a_long_random_hex_string_for_local_dev_only

# LLM kill switch (Phase 3+). Keep false until Phase 3 is wired up.
LLM_ENABLED=false

# OpenAI (Phase 3+). Leave blank until you have a dev-scoped key with spending cap.
OPENAI_API_KEY=
OPENAI_MODEL_MARKING=
OPENAI_MODEL_GENERATION=
OPENAI_MODEL_EMBEDDING=text-embedding-3-small

# Admin bootstrap (used only by scripts/seed on first run)
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=change_me_on_first_login
